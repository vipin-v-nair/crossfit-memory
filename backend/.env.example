# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# Populated after running `python -m crossfit_coach.memory_setup` once
AGENT_ENGINE_ID=

# App identity (used by ADK + Memory Bank scoping)
APP_NAME=crossfit_memory_demo
DEFAULT_USER_ID=demo_athlete

# Optional: for staging deployment
STAGING_BUCKET=gs://your-bucket-name
